---
import { splitInline } from "@/lib/inline";
import type { ArticleFigure as ArticleFigureData } from "@/lib/types";
import { withBase } from "@/lib/url";

type Props = ArticleFigureData;

const { src, alt, caption, width, height } = Astro.props;
---

<figure class="article-figure">
  <img
    src={withBase(src)}
    alt={alt}
    width={width}
    height={height}
    loading="lazy"
    decoding="async"
    class="article-figure__image"
  />
  <figcaption class="article-figure__caption">
    {splitInline(caption).map((part) =>
      typeof part === "string" ? part : <code>{part.code}</code>
    )}
  </figcaption>
</figure>
