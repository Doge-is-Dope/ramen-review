---
import ArticleBody from "@/components/ArticleBody.astro";
import ArticleHero from "@/components/ArticleHero.astro";
import SiteFooter from "@/components/SiteFooter.astro";
import TopBar from "@/components/TopBar.astro";
import { sections } from "@/data/article";
import { profile } from "@/data/profile";
import BaseLayout from "@/layouts/BaseLayout.astro";

const title = "RAMEN Case Study · Clement Liang";
const description =
  "How I planned, designed, built, and validated RAMEN — an agent platform with a chat product and Chrome-extension companion.";
---

<BaseLayout title={title} description={description}>
  <TopBar activePage="caseStudy" />

  <main class="article-shell">
    <ArticleHero profile={profile} />
    <ArticleBody sections={sections} />
  </main>

  <SiteFooter />
</BaseLayout>
